# ===== 国服 Riot API =====

# API 基址
RIOT_PD_BASE=https://alpha1-pd-redge.val.qq.com
RIOT_SHARED_BASE=https://alpha1-shared-redge.val.qq.com

# 方式一：抓包填 Token（Fiddler 从客户端请求复制 Header）
RIOT_ACCESS_TOKEN=eyJraWQiOiJzMSIs...
RIOT_ENTITLEMENTS_JWT=eyJraWQiOiJrMSIs...
RIOT_CLIENT_VERSION=release-china-12.11-shipping-12-4815700

# 方式二：启动瓦罗兰特客户端，自动读 lockfile 拿 Token + 解析 Name#Tag
# RIOT_LOCKFILE_PATH=C:\Users\你\AppData\Local\Riot Games\Riot Client\Config\lockfile

# 公开后备 API（默认开启，没开客户端时自动用；不需要配 Token）
# 完全独立运行时设为 false
# VALCN_FALLBACK=false

# 自定义后备 API 基址（一般不用改）
# VALCN_BASE_URL=https://你的后备服务

# ===== 服务器部署（复制为 .env.production）=====
# PORT=3000
# 部署后定期更新 RIOT_ACCESS_TOKEN（约 1 小时过期）
# 对局认人 /live 无法在服务器使用，仅本机开发可用
