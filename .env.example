# ===== 国服 Riot API（基址固定，一般不用改）=====
RIOT_PD_BASE=https://alpha1-pd-redge.val.qq.com
RIOT_SHARED_BASE=https://alpha1-shared-redge.val.qq.com

# ===== 双端模式 =====
# website = 官网（介绍 + 公用池查询 + 下载页，不读本机 session.json）
# client   = 本机成品（Companion / 对局 / 老好人贡献到官网）
# 官网部署见 .env.website.example
# NEXT_PUBLIC_APP_MODE=website
# NEXT_PUBLIC_APP_MODE=client
# NEXT_PUBLIC_SITE_URL=https://valcn.suiran.xyz
# 客户端 dev 本地 UI 可用 http://127.0.0.1:3000；老好人贡献走下面专用地址
# NEXT_PUBLIC_POOL_SITE_URL=https://valcn.suiran.xyz

# ===== 官网公用 Token 池（老好人模式贡献）=====
# SESSION_POOL_FILE=./data/session-pool.json
# SESSION_POOL_CONTRIBUTE=true
# SESSION_POOL_ENCRYPTION_KEY=   # 官网必配，见 scripts/generate-pool-secrets.mjs
# SESSION_POOL_CONTRIBUTE_SECRET=
# SESSION_POOL_READ_SECRET=

# ===== 会话优先级：env → session.json → 公用池 → 公开后备 → lockfile =====
# VALCN_FALLBACK=false
# VALCN_FALLBACK_URL=https://valcn.top/api/session/latest
# RIOT_SESSION_URL=https://你的域名/api/session/latest

# 可选：伴生程序自动写入的 session 文件（免手填 Token）
# 默认 %LOCALAPPDATA%\VAL-CN\session.json
# RIOT_SESSION_FILE=C:\Users\你\AppData\Local\VAL-CN\session.json

# 可选：运维手动覆盖 Token（不推荐日常使用）
# RIOT_ACCESS_TOKEN=eyJraWQiOiJzMSIs...
# RIOT_ENTITLEMENTS_JWT=eyJraWQiOiJrMSIs...
# RIOT_CLIENT_VERSION=release-china-12.11-shipping-12-4815700

# ===== 服务器部署 =====
# PORT=3000
# 生产环境保持 VALCN_FALLBACK=true 即可零配置运行
