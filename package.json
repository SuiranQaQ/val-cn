{
  "name": "val-cn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:session": "node scripts/check-session.mjs",
    "companion": "node companion/index.mjs",
    "companion:install-ca": "powershell -NoProfile -ExecutionPolicy Bypass -File companion/scripts/install-ca.ps1",
    "companion:ca": "companion\\scripts\\install-ca.cmd",
    "package:local": "powershell -ExecutionPolicy Bypass -File scripts/package-local.ps1",
    "package:website": "powershell -ExecutionPolicy Bypass -File scripts/package-website.ps1",
    "setup:pool-secrets": "node scripts/generate-pool-secrets.mjs --write",
    "setup:pool-secrets:force": "node scripts/generate-pool-secrets.mjs --write --force",
    "sync:pool-server": "powershell -ExecutionPolicy Bypass -File scripts/sync-pool-to-server.ps1",
    "desktop": "npm run dev --prefix desktop",
    "desktop:install": "npm install --prefix desktop",
    "desktop:prod": "npm start --prefix desktop"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.17.0",
    "modern-screenshot": "^4.7.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
